API_URL=https://dev-api.example
DEPLOY_CLIENT_DIR=/home2/ec2-user/dongle.front.dev/dongle.client.dev
DEPLOY_ADMIN_DIR=/home2/ec2-user/dongle.front.dev/dongle.admin.dev

# Sentry runtime env for PM2
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=local-dev

CLIENT_NEXT_PUBLIC_SENTRY_DSN=<client-public-dsn>
CLIENT_SENTRY_DSN=<client-server-dsn-or-same-as-public>
