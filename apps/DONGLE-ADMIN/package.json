{
    "name": "dongle-admin",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": " rm -rf .next && next dev --port 4001",
        "start:e2e": "next start --port 4001",
        "start:dev": "next start --port 4001",
        "build": "rm -rf .next && next build",
        "build:dev": "rm -rf .next && env-cmd -f .env.development next build",
        "build:prod": "rm -rf .next && NODE_ENV=production NEXT_IGNORE_ENV_LOCAL=1 next build",
        "build:standalone": "rm -rf .next && next build",
        "build:standalone:dev": "rm -rf .next && env-cmd -f .env.development next build",
        "build:standalone:prod": "rm -rf .next && NODE_ENV=production NEXT_IGNORE_ENV_LOCAL=1 next build",
        "deploy:standalone": "pnpm run build:standalone && cp -r .next/static .next/standalone/apps/DONGLE-ADMIN/.next/ && cp -r public .next/standalone/apps/DONGLE-ADMIN/",
        "deploy:standalone:dev": "pnpm run build:standalone:dev && cp -r .next/static .next/standalone/apps/DONGLE-ADMIN/.next/ && cp -r public .next/standalone/apps/DONGLE-ADMIN/",
        "deploy:standalone:prod": "pnpm run build:standalone:prod && cp -r .next/static .next/standalone/apps/DONGLE-ADMIN/.next/ && cp -r public .next/standalone/apps/DONGLE-ADMIN/",
        "start": "next start",
        "lint": "next lint",
        "storybook": "storybook dev -p 6006",
        "storybook:build": "storybook build",
        "test": "vitest run --project admin",
        "type": "tsc --noEmit",
        "mock": "tsx src/mocks/server.ts",
        "mock:dev": "tsx watch src/mocks/server.ts"
    },
    "dependencies": {
        "@dongle/api": "workspace:*",
        "@dongle/content": "workspace:*",
        "@dongle/rich-text": "workspace:*",
        "@dongle/service": "workspace:*",
        "@dongle/types": "workspace:*",
        "@dongle/ui": "workspace:*",
        "@sentry/nextjs": "^10.20.0",
        "@hookform/resolvers": "^5.2.2",
        "@radix-ui/react-dialog": "^1.1.14",
        "@radix-ui/react-dropdown-menu": "^2.1.15",
        "@radix-ui/react-label": "^2.1.7",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-select": "^2.2.5",
        "@radix-ui/react-separator": "^1.1.7",
        "@radix-ui/react-slot": "^1.2.3",
        "@radix-ui/react-tabs": "^1.1.12",
        "@radix-ui/react-tooltip": "^1.2.7",
        "@tiptap/extension-image": "^3.20.1",
        "@tiptap/extension-link": "^3.20.1",
        "@tiptap/extension-placeholder": "^3.20.1",
        "@tiptap/react": "^3.20.1",
        "@tiptap/starter-kit": "^3.20.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "dayjs": "^1.11.18",
        "embla-carousel-react": "^8.6.0",
        "jose": "^6.1.0",
        "js-cookie": "^3.0.5",
        "lucide-react": "^0.525.0",
        "next": "15.5.9",
        "react": "^19.2.1",
        "react-day-picker": "^9.9.0",
        "react-dom": "^19.2.1",
        "react-hook-form": "^7.63.0",
        "sonner": "^2.0.6",
        "tailwind-merge": "^3.3.1",
        "zod": "^4.1.9"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3",
        "@mswjs/http-middleware": "^0.10.3",
        "@storybook/nextjs": "^9.0.16",
        "@tailwindcss/postcss": "^4",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.3",
        "@types/js-cookie": "^3.0.6",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "cors": "^2.8.5",
        "env-cmd": "^11.0.0",
        "eslint": "^9",
        "eslint-config-next": "15.5.9",
        "express": "^4.18.0",
        "msw": "^2.11.1",
        "tailwindcss": "^4",
        "tsx": "^4.20.5",
        "tw-animate-css": "^1.3.5",
        "typescript": "^5"
    }
}
