# 선택적 수동 SCP 배포용 환경변수 (루트에 .env.deploy 로 복사 후 값 채우기)
# dev는 Render, prod는 GitHub Actions 배포를 기본으로 사용한다.
# cp .env.deploy.example .env.deploy

# SSH PEM 키 경로 (비워두면 기본 키 사용)
DEPLOY_PEM=~/.ssh/my-key.pem

DEPLOY_USER=deploy
DEPLOY_HOST=dongle.wavers.kr
# 서버에서 standalone 을 직접 업로드할 경로 (server.js 가 있는 디렉터리)
DEPLOY_CLIENT_DIR=/home/ec2-user/dongle.front.manual/dongle.client
DEPLOY_ADMIN_DIR=/home/ec2-user/dongle.front.manual/dongle.admin

# Sentry GitHub Secrets names used by CI
# CLIENT_NEXT_PUBLIC_SENTRY_DSN
# CLIENT_SENTRY_AUTH_TOKEN
# CLIENT_SENTRY_ORG
# CLIENT_SENTRY_PROJECT
# ADMIN_NEXT_PUBLIC_SENTRY_DSN
# ADMIN_SENTRY_AUTH_TOKEN
# ADMIN_SENTRY_ORG
# ADMIN_SENTRY_PROJECT
