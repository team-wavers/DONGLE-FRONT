{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@dongle/api": ["packages/api/src/index.ts"],
            "@dongle/api/*": ["packages/api/src/*"],
            "@dongle/service": ["packages/service/src/index.ts"],
            "@dongle/service/*": ["packages/service/src/*"],
            "@dongle/types": ["packages/types/src/index.ts"],
            "@dongle/types/*": ["packages/types/src/*"],
            "@dongle/rich-text": ["packages/rich-text/src/index.ts"],
            "@dongle/rich-text/*": ["packages/rich-text/src/*"],
            "@dongle/ui": ["packages/ui/src/index.ts"],
            "@dongle/ui/*": ["packages/ui/src/*"],
        },
        "target": "ES2017",
        "lib": ["dom", "dom.iterable", "esnext"],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "incremental": true,
    },
}
