API_URL=https://api.example.com
DEPLOY_CLIENT_DIR_PROD=/home2/ec2-user/dongle.front.prod/dongle.client.prod
DEPLOY_ADMIN_DIR_PROD=/home2/ec2-user/dongle.front.prod/dongle.admin.prod
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=<base64-encoded-32-byte-key>

# Sentry runtime env for PM2
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=<github-sha-or-release-id>

CLIENT_NEXT_PUBLIC_SENTRY_DSN=<client-public-dsn>
CLIENT_SENTRY_DSN=<client-server-dsn-or-same-as-public>
CLIENT_SENTRY_ENVIRONMENT=production
CLIENT_SENTRY_RELEASE=<github-sha-or-release-id>

ADMIN_NEXT_PUBLIC_SENTRY_DSN=<admin-public-dsn>
ADMIN_SENTRY_DSN=<admin-server-dsn-or-same-as-public>
ADMIN_SENTRY_ENVIRONMENT=production
ADMIN_SENTRY_RELEASE=<github-sha-or-release-id>
