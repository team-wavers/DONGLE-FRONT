# Required GitHub Actions secrets for prod deploy
PROD_API_URL=https://api.example.com
LIGHTSAIL_HOST=example.compute.amazonaws.com
LIGHTSAIL_SSH_KEY=<private-key-content>
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=<base64-encoded-32-byte-key>
CLIENT_NEXT_PUBLIC_SENTRY_DSN=<client-public-dsn>
ADMIN_NEXT_PUBLIC_SENTRY_DSN=<admin-public-dsn>

# Optional external healthcheck URLs
PROD_CLIENT_HEALTHCHECK_URL=https://dongle.example.com/api/health
PROD_ADMIN_HEALTHCHECK_URL=https://admin.dongle.example.com/api/health

# Optional Sentry sourcemap upload secrets
CLIENT_SENTRY_AUTH_TOKEN=<client-sentry-auth-token>
CLIENT_SENTRY_ORG=<client-sentry-org>
CLIENT_SENTRY_PROJECT=<client-sentry-project>
ADMIN_SENTRY_AUTH_TOKEN=<admin-sentry-auth-token>
ADMIN_SENTRY_ORG=<admin-sentry-org>
ADMIN_SENTRY_PROJECT=<admin-sentry-project>
